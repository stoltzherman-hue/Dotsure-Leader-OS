# DOTSURE LEADER OS — Environment Variables
# Fill in your values then rename this file to .env.local
# Place in the project root: C:\Users\Hermans\dotsure-leader-os\.env.local
#
# DO NOT use the harness Supabase project (guwqrtxfnymhmrgqgavx)
# This must be a NEW Supabase project

# New Supabase project (create at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=your_new_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_new_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_new_supabase_service_role_key_here

# Anthropic API key - server-side only, never exposed to client
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: set to true to bypass login entirely (e.g. while Supabase auth
# is unavailable). Leave unset/false once auth is working.
NEXT_PUBLIC_SKIP_AUTH=false
